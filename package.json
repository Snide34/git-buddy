{
  "name": "dev-productivity-widget",
  "version": "1.0.0",
  "description": "Desktop widget tracking LeetCode and GitHub productivity",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [
    "productivity",
    "widget",
    "leetcode",
    "github"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "auto-launch": "^5.0.6",
    "axios": "^1.6.8",
    "electron-store": "^8.2.0",
    "lucide-react": "^1.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.6",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.devwidget.app",
    "productName": "DevWidget",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
